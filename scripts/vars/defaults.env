# Local Make/Zarf orchestration defaults.
#
# These values are not container runtime env. Runtime config belongs in Kubernetes
# manifests, UDS Package CRs, component Dockerfiles, and zarf.yaml files.

UDS_POC_REGISTRY=localhost:5001
UDS_POC_REPOSITORY=uds-poc
UDS_POC_VERSION=0.1.0

UDS_POC_PLATFORM_NAME=uds-poc-platform
UDS_POC_PLATFORM_NAMESPACE=uds-poc

DOCS_NAME=docs
DOCS_NAMESPACE=docs
DOCS_PACKAGE_DIR=components/docs

CATALOG_POC_NAME=catalog-poc
CATALOG_POC_NAMESPACE=catalog-poc
CATALOG_POC_PACKAGE_DIR=components/catalog-poc
