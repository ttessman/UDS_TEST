# Comma-separated OCI references to inspect. Keep registry credentials server-side.
# Start with packages you know are public/reachable from your environment.
UDS_REGISTRY_PACKAGE_REFS=oci://ghcr.io/defenseunicorns/packages/uds/core:latest,oci://ghcr.io/defenseunicorns/packages/uds/podinfo:latest

# Optional: path to a captured registry catalog JSON payload shaped like
# registry.defenseunicorns.com's `catalog.airgap-store.repos[]` data.
# When set, GET /api/uds/packages uses this catalog shape for card metadata.
UDS_REGISTRY_CATALOG_PATH=

# Optional: direct catalog JSON endpoint if/when available or authenticated.
UDS_REGISTRY_CATALOG_URL=

# Optional: official UDS Core local demo bundle ref used by `make deploy-core`.
UDS_CORE_BUNDLE_REF=k3d-core-demo:latest

# Optional: set to true to let POST /api/uds/packages/:id/install execute deploy commands.
# Without this, install requests return the command preview and do not deploy.
UDS_POC_ENABLE_INSTALL=false

# Optional: URL scheme used when opening UDS Package CR status.endpoints.
UDS_APP_URL_SCHEME=https

# Optional: local OCI refs such as oci://localhost:5001/... use --plain-http by default.
UDS_REGISTRY_PLAIN_HTTP=true

# Optional credentials for private OCI registries, consumed only by server-side CLI processes.
UDS_REGISTRY_USERNAME=
UDS_REGISTRY_PASSWORD=
